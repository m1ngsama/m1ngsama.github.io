{
  "name": "m1ngsama-site",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "sync:pages": "npm run build && node scripts/sync-pages.mjs",
    "verify:pages": "node scripts/verify-pages.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "gsap": "3.15.0",
    "lenis": "1.3.25",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/three": "0.185.1",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
